<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android"> // 标题栏 
    <LinearLayout android:gravity="bottom" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="0.0dp">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
            <ImageView android:id="@id/healthkit_auth_back_icon" android:background="?android:selectableItemBackground" android:src="@drawable/healthkit_back_icon" style="@style/healthkit_auth_nav_icon" />
        </LinearLayout>
        <LinearLayout android:gravity="bottom" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:id="@id/healthkit_auth_title" style="@style/healthkit_auth_nav_title" />
        </LinearLayout>
    </LinearLayout>
    <WebView android:id="@id/healthkit_webView" android:layout_width="match_parent" android:layout_height="match_parent" />
</LinearLayout>
