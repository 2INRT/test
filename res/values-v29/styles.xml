<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MapActivity.FullScreen" parent="@android:style/Theme.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@color/c_1</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@style/NoAnimation</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>
    <style name="Theme.MapActivity.FullScreen.LTR" parent="@android:style/Theme.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@color/c_1</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@style/NoAnimation</item>
        <item name="android:textDirection">ltr</item>
        <item name="android:layoutDirection">ltr</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>
    <style name="Theme.Splash.FullScreen" parent="@android:style/Theme.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@drawable/fullscreen_splash_drawable_en</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@style/NoAnimation</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>
    <style name="Theme.Splash.FullScreen.Quick" parent="@android:style/Theme.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@drawable/fullscreen_splash_quick_drawable</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@style/NoAnimation</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>
    <style name="Theme.WebView.Light" parent="@style/Theme.MapActivity.FullScreen">
        <item name="android:isLightTheme">true</item>
    </style>
    <style name="Theme.WebView.Light.LTR" parent="@style/Theme.MapActivity.FullScreen.LTR">
        <item name="android:isLightTheme">true</item>
    </style>
</resources>
