{
  "layout_width": "match_parent",
  "layout_height": "match_parent",
  "type": "constraint",
  "id": "hiboard_widget_id_container",
  "package": "com.autonavi.minimap",
  "child": [
    {
      "id": "hiboard_widget_id_bg",
      "layout_width": "match_parent",
      "layout_height": "match_parent",
      "src": "@drawable/hiboard_root_bg_default",
      "scaleType": "centerCrop",
      "type": "image"
    },
    {
      "layout_width": "0dp",
      "layout_height": "60dp",
      "layout_constraintTop_toTopOf": "hiboard_widget_id_search_container",
      "layout_constraintBottom_toBottomOf": "hiboard_widget_id_search_container",
      "layout_constraintEnd_toEndOf": "parent",
      "layout_constraintStart_toStartOf": "parent",
      "type": "image"
    },
    {
      "id": "hiboard_widget_id_search_container",
      "type": "constraint",
      "layout_width": "0dp",
      "layout_height": "36dp",
      "layout_marginTop": "12dp",
      "layout_marginStart": "12dp",
      "layout_marginEnd": "12dp",
      "layout_constraintTop_toTopOf": "parent",
      "layout_constraintEnd_toEndOf": "parent",
      "layout_constraintStart_toStartOf": "parent",
      "background": "@drawable/hiboard_edit_shape_bg",
      "child":[
        {
          "id": "hiboard_widget_id_search_icon",
          "layout_width": "20dp",
          "layout_height": "20dp",
          "src": "@drawable/hiboard_logo_normal",
          "type": "image",
          "scaleType": "centerCrop",
          "layout_constraintStart_toStartOf": "parent",
          "layout_constraintTop_toTopOf": "parent",
          "layout_constraintBottom_toBottomOf": "parent",
          "layout_marginStart": "8dp"
        },
        {
          "type": "text",
          "id": "hiboard_widget_id_search_text",
          "layout_width": "0dp",
          "layout_height": "match_parent",
          "layout_constraintStart_toEndOf": "hiboard_widget_id_search_icon",
          "layout_constraintEnd_toEndOf": "parent",
          "layout_constraintTop_toTopOf": "parent",
          "layout_marginStart": "8dp",
          "layout_marginEnd": "8dp",
          "textColor": "@color/hiboard_edit_text_color",
          "textSize": "12dp",
          "includeFontPadding": false,
          "singleLine": true,
          "gravity": "left|center_vertical",
          "textAlignment": "gravity",
          "ellipsize": "end",
          "text": "搜地点、导航"
        }
      ]
    },
    {
      "id": "hiboard_widget_id_tv0",
      "layout_width": "54dp",
      "layout_height": "15dp",
      "layout_marginBottom": "16dp",
      "layout_marginEnd": "9dp",
      "layout_marginStart": "19dp",
      "text": "",
      "textSize": "12dp",
      "textColor": "@color/hiboard_tool_text_color",
      "textAlignment": "center",
      "layout_constraintStart_toStartOf": "parent",
      "layout_constraintEnd_toStartOf": "hiboard_widget_id_tv1",
      "layout_constraintBottom_toBottomOf": "parent",
      "tools:srcCompat": "@tools:sample\/avatars",
      "includeFontPadding": false,
      "type": "text"
    },
    {
      "id": "hiboard_widget_id_iv0",
      "layout_width": "54dp",
      "layout_height": "54dp",
      "layout_marginEnd": "10dp",
      "layout_marginStart": "20dp",
      "src": "@drawable/hiboard_toolbox_item_default",
      "layout_constraintEnd_toStartOf": "hiboard_widget_id_iv1",
      "layout_constraintBottom_toTopOf": "hiboard_widget_id_tv0",
      "layout_constraintStart_toStartOf": "parent",
      "tools:srcCompat": "@tools:sample\/avatars",
      "type": "image",
      "layout_marginBottom": "-2dp"
    },
    {
      "id": "hiboard_widget_id_tv1",
      "layout_width": "54dp",
      "layout_height": "15dp",
      "layout_marginBottom": "16dp",
      "layout_marginEnd": "19dp",
      "text": "",
      "textSize": "12dp",
      "textColor": "@color/hiboard_tool_text_color",
      "textAlignment": "center",
      "layout_constraintEnd_toEndOf": "parent",
      "layout_constraintBottom_toBottomOf": "parent",
      "layout_constraintStart_toEndOf": "hiboard_widget_id_tv0",
      "tools:srcCompat": "@tools:sample\/avatars",
      "includeFontPadding": false,
      "type": "text"
    },
    {
      "id": "hiboard_widget_id_iv1",
      "layout_width": "54dp",
      "layout_height": "54dp",
      "layout_marginEnd": "20dp",
      "src": "@drawable/hiboard_toolbox_item_default",
      "layout_constraintEnd_toEndOf": "parent",
      "layout_constraintBottom_toTopOf": "hiboard_widget_id_tv1",
      "layout_constraintStart_toEndOf": "hiboard_widget_id_iv0",
      "tools:srcCompat": "@tools:sample\/avatars",
      "type": "image",
      "layout_marginBottom": "-2dp"
    }
  ]
}